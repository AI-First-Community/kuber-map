<?xml version="1.0"?>
<rdf:RDF
    xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
    xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
    xmlns:owl="http://www.w3.org/2002/07/owl#"
    xmlns:skos="http://www.w3.org/2004/02/skos/core#"
    xmlns:av="https://spec.edmcouncil.org/fibo/ontology/FND/Utilities/AnnotationVocabulary/">

  <owl:Ontology rdf:about="https://spec.edmcouncil.org/fibo/ontology/FND/Mini/Mini/">
    <av:hasMaturityLevel rdf:resource="https://spec.edmcouncil.org/fibo/ontology/FND/Utilities/AnnotationVocabulary/Release"/>
  </owl:Ontology>

  <owl:ObjectProperty rdf:about="https://spec.edmcouncil.org/fibo/ontology/FND/Mini/Mini/relatesTo">
    <rdfs:label>relates to</rdfs:label>
  </owl:ObjectProperty>

  <owl:Class rdf:about="https://spec.edmcouncil.org/fibo/ontology/FND/Mini/Mini/Thing">
    <rdfs:label>thing</rdfs:label>
    <skos:definition>a thing</skos:definition>
  </owl:Class>

  <!-- SpecialThing: named superclass (is-a) + a typed relation hidden in an owl:Restriction
       whose filler is a cross-cluster Commons (CMNS) class. This is the crux the extractor must crack. -->
  <owl:Class rdf:about="https://spec.edmcouncil.org/fibo/ontology/FND/Mini/Mini/SpecialThing">
    <rdfs:subClassOf rdf:resource="https://spec.edmcouncil.org/fibo/ontology/FND/Mini/Mini/Thing"/>
    <rdfs:subClassOf>
      <owl:Restriction>
        <owl:onProperty rdf:resource="https://spec.edmcouncil.org/fibo/ontology/FND/Mini/Mini/relatesTo"/>
        <owl:someValuesFrom rdf:resource="https://www.omg.org/spec/Commons/PartiesAndSituations/Party"/>
      </owl:Restriction>
    </rdfs:subClassOf>
    <rdfs:label>special thing</rdfs:label>
    <skos:definition>a special thing</skos:definition>
  </owl:Class>

  <!-- RegionalThing carries en-US and en-GB labels (like FIBO's program/programme).
       The extractor must deterministically prefer en-US so bundles are reproducible. -->
  <owl:Class rdf:about="https://spec.edmcouncil.org/fibo/ontology/FND/Mini/Mini/RegionalThing">
    <rdfs:label xml:lang="en-GB">colourful thing</rdfs:label>
    <rdfs:label xml:lang="en-US">colorful thing</rdfs:label>
    <skos:definition>a regional thing</skos:definition>
    <skos:example>a colorful example</skos:example>
    <av:explanatoryNote>an explanatory note about regional things</av:explanatoryNote>
    <av:synonym>colourful item</av:synonym>
  </owl:Class>

  <!-- MultiFillerThing: one restriction with a NAMED someValuesFrom (Party) AND an anonymous
       unionOf class. The extractor must deterministically pick the named filler, never drop
       the relation because the store yielded the blank node first (hash-order bug). -->
  <owl:Class rdf:about="https://spec.edmcouncil.org/fibo/ontology/FND/Mini/Mini/MultiFillerThing">
    <rdfs:subClassOf>
      <owl:Restriction>
        <owl:onProperty rdf:resource="https://spec.edmcouncil.org/fibo/ontology/FND/Mini/Mini/relatesTo"/>
        <owl:someValuesFrom rdf:resource="https://www.omg.org/spec/Commons/PartiesAndSituations/Party"/>
        <owl:someValuesFrom>
          <owl:Class>
            <owl:unionOf rdf:parseType="Collection">
              <rdf:Description rdf:about="https://spec.edmcouncil.org/fibo/ontology/FND/Mini/Mini/Thing"/>
            </owl:unionOf>
          </owl:Class>
        </owl:someValuesFrom>
      </owl:Restriction>
    </rdfs:subClassOf>
    <rdfs:label>multi filler thing</rdfs:label>
  </owl:Class>

</rdf:RDF>
